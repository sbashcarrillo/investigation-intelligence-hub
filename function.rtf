function setupQueryIntelligenceHubSheetV2() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const tabs = {
    "Queries": [
      "Query ID", "Repository", "Status", "Version", "Category", "Query Name",
      "Description", "Purpose", "Link", "Inputs", "Returns", "Data Sources",
      "Tags", "SQL", "Use Cases", "Created By", "Created Date", "Updated By",
      "Last Updated", "Approved By", "Approved Date"
    ],

    "Categories": [
      "Repository", "Category", "Color", "Sort Order"
    ],

    "Repositories": [
      "Repository", "Name", "Full Name", "Description", "Accent Color", "Sort Order"
    ],

    "User Favorites": [
      "User Email", "Repository", "Query ID", "Favorited Date"
    ],

    "Change Log": [
      "Timestamp", "Query ID", "User Email", "Action", "Field", "Old Value", "New Value", "Version"
    ],

    "Admin Settings": [
      "Email", "Name", "Role", "Active"
    ]
  };

  Object.entries(tabs).forEach(([name, headers]) => {
    let sheet = ss.getSheetByName(name);
    if (!sheet) sheet = ss.insertSheet(name);

    sheet.clear();
    sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
    sheet.setFrozenRows(1);

    sheet.getRange(1, 1, 1, headers.length)
      .setFontWeight("bold")
      .setFontColor("#ffffff")
      .setBackground("#111827");

    if (!sheet.getFilter()) {
      sheet.getRange(1, 1, Math.max(sheet.getMaxRows(), 2), headers.length).createFilter();
    }

    sheet.autoResizeColumns(1, headers.length);
  });

  seedRepositoriesV2_(ss);
  seedCategoriesV2_(ss);
  seedAdminSettingsV2_(ss);
  applyValidationV2_(ss);
  applyFormattingV2_(ss);

  SpreadsheetApp.getUi().alert("Query Intelligence Hub v2 sheet setup complete.");
}

function seedRepositoriesV2_(ss) {
  const sheet = ss.getSheetByName("Repositories");

  const rows = [
    ["ORG", "Organized Repository", "Organized Repository", "Trusted queries for organized fraud investigations, digital activity, identity, transactions, claims, and ring development.", "#60a5fa", 10],
    ["LE", "Law Enforcement Repository", "Law Enforcement Repository", "Queries supporting law enforcement engagements, legal process tracking, records pulls, and case support.", "#a78bfa", 20],
    ["SUB", "Subpoena Repository", "Subpoena Repository", "Queries supporting subpoena intake, record production, fulfillment, and delivery workflows.", "#34d399", 30]
  ];

  sheet.getRange(2, 1, rows.length, rows[0].length).setValues(rows);
}

