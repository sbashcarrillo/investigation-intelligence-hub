\f0\fs24 \cf0 function setupFPIHubDataContractV1() \{\
  const ss = SpreadsheetApp.getActiveSpreadsheet();\
\
  const tabs = \{\
    "Queries": [\
      "Query ID", "Repository", "Category", "Query Name", "Description",\
      "Purpose", "Inputs", "Returns", "Data Sources", "Tags", "SQL",\
      "Use Cases", "Link", "Updated By", "Last Updated", "Owner",\
      "Reviewer", "Status", "Version", "Replacement Query ID", "Notes"\
    ],\
    "Categories": [\
      "Repository", "Category", "Description", "Color", "Sort Order", "Active"\
    ],\
    "Repositories": [\
      "Repository", "Display Name", "Description", "Icon", "Color", "Sort Order", "Enabled"\
    ],\
    "User Favorites": [\
      "User Email", "Repository", "Query ID", "Favorited Date"\
    ],\
    "Change Log": [\
      "Timestamp", "User Email", "Query ID", "Action", "Notes"\
    ]\
  \};\
\
  Object.entries(tabs).forEach(([name, headers]) => \{\
    let sheet = ss.getSheetByName(name);\
    if (!sheet) sheet = ss.insertSheet(name);\
\
    sheet.clear();\
    sheet.getRange(1, 1, 1, headers.length).setValues([headers]);\
    sheet.setFrozenRows(1);\
\
    sheet.getRange(1, 1, 1, headers.length)\
      .setFontWeight("bold")\
      .setBackground("#111827")\
      .setFontColor("#ffffff");\
\
    if (!sheet.getFilter()) \{\
      sheet.getRange(1, 1, Math.max(sheet.getMaxRows(), 2), headers.length).createFilter();\
    \}\
\
    sheet.autoResizeColumns(1, headers.length);\
  \});\
\
  seedRepositoriesV1_(ss);\
  seedCategoriesV1_(ss);\
  applyValidationV1_(ss);\
  applyFormattingV1_(ss);\
\
  SpreadsheetApp.getUi().alert("FPI Intelligence Hub Data Contract v1.0 setup complete.");\
\}\
\
function seedRepositoriesV1_(ss) \{\
  const sheet = ss.getSheetByName("Repositories");\
  const rows = [\
