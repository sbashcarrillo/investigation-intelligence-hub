function seedAdminSettingsV2_(ss) {
  const sheet = ss.getSheetByName("Admin Settings");

  const userEmail = Session.getActiveUser().getEmail() || "your.email@company.com";

  const rows = [
    [userEmail, "Your Name", "Admin", true]
  ];

  sheet.getRange(2, 1, rows.length, rows[0].length).setValues(rows);
}

function applyValidationV2_(ss) {
  const queries = ss.getSheetByName("Queries");
  const admin = ss.getSheetByName("Admin Settings");

  const repoRule = SpreadsheetApp.newDataValidation()
    .requireValueInRange(ss.getSheetByName("Repositories").getRange("A2:A"), true)
    .setAllowInvalid(false)
    .build();

  const categoryRule = SpreadsheetApp.newDataValidation()
    .requireValueInRange(ss.getSheetByName("Categories").getRange("B2:B"), true)
    .setAllowInvalid(true)
    .build();

  const statusRule = SpreadsheetApp.newDataValidation()
    .requireValueInList(["Draft", "Review", "Production", "Deprecated"], true)
    .setAllowInvalid(false)
    .build();

  const roleRule = SpreadsheetApp.newDataValidation()
    .requireValueInList(["User", "Admin"], true)
    .setAllowInvalid(false)
    .build();

  queries.getRange("B2:B").setDataValidation(repoRule);
  queries.getRange("C2:C").setDataValidation(statusRule);
  queries.getRange("E2:E").setDataValidation(categoryRule);

  admin.getRange("C2:C").setDataValidation(roleRule);
  admin.getRange("D2:D").insertCheckboxes();
}

function applyFormattingV2_(ss) {
  const queries = ss.getSheetByName("Queries");
  const changeLog = ss.getSheetByName("Change Log");

  queries.setColumnWidths(1, 1, 120);
  queries.setColumnWidths(2, 3, 120);
  queries.setColumnWidths(5, 1, 180);
  queries.setColumnWidths(6, 1, 280);
  queries.setColumnWidths(7, 2, 360);
  queries.setColumnWidths(9, 1, 220);
  queries.setColumnWidths(10, 5, 260);
  queries.setColumnWidths(14, 1, 650);
  queries.setColumnWidths(16, 6, 180);

  queries.getRange("G:H").setWrap(true);
  queries.getRange("J:O").setWrap(true);

  changeLog.setColumnWidths(1, 8, 180);
  changeLog.getRange("F:G").setWrap(true);

  const statusRange = queries.getRange("C2:C");

  const rules = [
    makeTextRuleV2_(statusRange, "Draft", "#e5e7eb"),
    makeTextRuleV2_(statusRange, "Review", "#fef3c7"),
    makeTextRuleV2_(statusRange, "Production", "#bbf7d0"),
    makeTextRuleV2_(statusRange, "Deprecated", "#fecaca")
  ];

  queries.setConditionalFormatRules(rules);
}

function makeTextRuleV2_(range, text, color) {
  return SpreadsheetApp.newConditionalFormatRule()
    .whenTextEqualTo(text)
    .setBackground(color)
    .setRanges([range])
    .build();
}
