\
function applyValidationV1_(ss) \{\
  const queries = ss.getSheetByName("Queries");\
\
  const repoRule = SpreadsheetApp.newDataValidation()\
    .requireValueInRange(ss.getSheetByName("Repositories").getRange("A2:A"), true)\
    .setAllowInvalid(false)\
    .build();\
\
  const categoryRule = SpreadsheetApp.newDataValidation()\
    .requireValueInRange(ss.getSheetByName("Categories").getRange("B2:B"), true)\
    .setAllowInvalid(true)\
    .build();\
\
  const statusRule = SpreadsheetApp.newDataValidation()\
    .requireValueInList(["Draft", "Pending Review", "Needs Changes", "Production", "Retired"], true)\
    .setAllowInvalid(false)\
    .build();\
\
  queries.getRange("B2:B").setDataValidation(repoRule);\
  queries.getRange("C2:C").setDataValidation(categoryRule);\
  queries.getRange("R2:R").setDataValidation(statusRule);\
\}\
\
function applyFormattingV1_(ss) \{\
  const queries = ss.getSheetByName("Queries");\
\
  queries.setColumnWidth(1, 120);\
  queries.setColumnWidth(2, 120);\
  queries.setColumnWidth(3, 180);\
  queries.setColumnWidth(4, 280);\
  queries.setColumnWidth(5, 360);\
  queries.setColumnWidth(6, 420);\
  queries.setColumnWidth(7, 240);\
  queries.setColumnWidth(8, 240);\
  queries.setColumnWidth(9, 240);\
  queries.setColumnWidth(10, 260);\
  queries.setColumnWidth(11, 650);\
  queries.setColumnWidth(12, 300);\
  queries.setColumnWidth(13, 240);\
  queries.setColumnWidth(21, 360);\
\
  queries.getRange("E:F").setWrap(true);\
  queries.getRange("G:I").setWrap(true);\
  queries.getRange("K:L").setWrap(true);\
  queries.getRange("U:U").setWrap(true);\
\
  const statusRange = queries.getRange("R2:R");\
\
  const rules = [\
    makeTextRuleV1_(statusRange, "Draft", "#e5e7eb"),\
    makeTextRuleV1_(statusRange, "Pending Review", "#fef3c7"),\
    makeTextRuleV1_(statusRange, "Needs Changes", "#fed7aa"),\
    makeTextRuleV1_(statusRange, "Production", "#bbf7d0"),\
    makeTextRuleV1_(statusRange, "Retired", "#fecaca")\
  ];\
\
  queries.setConditionalFormatRules(rules);\
\}\
\
function makeTextRuleV1_(range, text, color) \{\
  return SpreadsheetApp.newConditionalFormatRule()\
    .whenTextEqualTo(text)\
    .setBackground(color)\
    .setRanges([range])\
    .build();\
\}}